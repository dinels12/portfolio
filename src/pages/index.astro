---
import { getCollection } from "astro:content";
import Contact from "../components/Contact.astro";
import Experience from "../components/Experience.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Nav from "../components/Nav.astro";
import Projects from "../components/Projects.astro";
import Base from "../layouts/Base.astro";
import "../styles/global.css";

// Latest 3 blog posts for homepage preview
// const posts = await Astro.glob("../content/blog/*.mdx");
// const latestPosts = posts
//   .map((p) => ({ ...p.frontmatter, url: p.url }))
//   .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
//   .slice(0, 3);
const posts = await getCollection("blog");
// // You can sort them by date as needed
const latestPosts = posts.sort((a: any, b: any) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base>
  <Nav />

  <main>
    <Hero />

    <Projects />

    <!-- Blog preview strip -->
    {
      latestPosts.length > 0 && (
        <section class="py-20 bg-surface border-y border-border">
          <div class="max-w-5xl mx-auto px-6">
            <div class="flex items-end justify-between mb-10">
              <div>
                <p class="font-mono text-xs text-accent uppercase tracking-widest mb-2">Writing</p>
                <h2 class="font-display text-3xl font-bold tracking-tight text-ink">Latest from the blog</h2>
              </div>
              <a
                href="/blog"
                class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted hover:text-ink no-underline transition-colors"
              >
                All posts
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {latestPosts.map(({ data: post, slug }: any) => (
                <a
                  href={`/blog/${slug}`}
                  class="reveal group bg-canvas border border-border rounded-xl p-6 no-underline hover:border-border2 hover:shadow-sm transition-all duration-200 flex flex-col"
                >
                  <div class="mb-3">
                    {post.tag && (
                      <span class="text-xs bg-tag-bg text-tag-text border border-blue-100 px-2.5 py-0.5 rounded-full font-medium font-mono">
                        {post.tag}
                      </span>
                    )}
                  </div>
                  <h3 class="font-display font-semibold text-base text-ink group-hover:text-accent transition-colors leading-snug mb-2 flex-1">
                    {post.title}
                  </h3>
                  <p class="text-sm text-muted leading-relaxed mb-4 line-clamp-2">{post.excerpt}</p>
                  <div class="flex items-center justify-between">
                    <span class="font-mono text-xs text-muted">
                      {new Date(post.date).toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                    {post.readTime && <span class="font-mono text-xs text-muted">{post.readTime}</span>}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <Experience />

    <Contact />
  </main>

  <Footer />
</Base>
