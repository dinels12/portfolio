---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-canvas py-8">
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="font-display text-sm text-muted">© {year} Daniel Suarez</span>
    <div class="flex items-center gap-5">
      <a
        href="https://github.com/dinels12"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-ink transition-colors no-underline text-sm font-medium">GitHub</a
      >
      <a
        href="https://linkedin.com/in/dinels"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted hover:text-ink transition-colors no-underline text-sm font-medium">LinkedIn</a
      >
      <a
        href="mailto:dinels12@gmail.com"
        class="text-muted hover:text-ink transition-colors no-underline text-sm font-medium">Email</a
      >
    </div>
    <span class="font-mono text-xs text-muted/60">Built with Astro + Tailwind</span>
  </div>
</footer>
