---
const categories = [
  {
    label: "Frontend",
    tags: ["React", "Next.js", "Astro", "TailwindCSS", "HTML", "CSS", "JavaScript"],
  },
  {
    label: "Mobile",
    tags: ["React Native", "Expo", "Zustand", "NativeWind"],
  },
  {
    label: "Backend",
    tags: ["Node.js", "NestJS", "GraphQL", "REST APIs", "gRPC"],
  },
  {
    label: "Cloud & DevOps",
    tags: ["AWS ECS", "EC2", "S3", "CloudFront", "Route53", "Docker", "Redis", "BigQuery"],
  },
  {
    label: "Payments",
    tags: ["Stripe", "PayPal", "Authorize.net"],
  },
  {
    label: "CI/CD & Tools",
    tags: ["Git", "GitHub Actions", "GitLab CI/CD", "Linux"],
  },
];
---

<section id="skills" class="py-24">
  <div class="max-w-3xl mx-auto px-8">

    <div class="flex items-center gap-3 mb-3">
      <span class="font-mono text-xs text-accent uppercase tracking-widest">Stack</span>
      <span class="flex-1 h-px bg-border"></span>
    </div>
    <h2 class="font-display font-semibold text-3xl tracking-tighter text-body mb-12">Technical Skills</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map(cat => (
        <div class="fade-in bg-bg2 border border-border rounded-xl p-5 hover:border-white/[0.12] hover:-translate-y-0.5 transition-all duration-200">
          <div class="font-mono text-xs text-accent uppercase tracking-widest mb-3">{cat.label}</div>
          <div class="flex flex-wrap gap-1.5">
            {cat.tags.map(tag => (
              <span class="text-xs bg-bg3 text-body border border-border px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
