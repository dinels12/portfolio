---
// To add your project screenshots:
// 1. Drop images into /public/projects/
// 2. Set image: "/projects/your-file.png" below
// 3. If no image, set image: null — a gradient placeholder renders instead

const projects = [
  {
    title: "Aloharmony",
    subtitle: "Meditation Platform",
    description:
      "Built the full product from scratch as CTO/Lead Engineer — React Native mobile app with offline-first architecture, NestJS + GraphQL backend (90+ endpoints), Next.js web platform, and complete AWS infrastructure. Scaled to 16k+ registered users and 1,300 daily active users.",
    image: "/projects/aloharmony.webp",
    placeholderGradient: "from-blue-50 to-indigo-100",
    tags: ["React Native", "Next.js", "NestJS", "GraphQL", "AWS", "Stripe"],
    metrics: [
      { value: "16k+", label: "Users" },
      { value: "1,300", label: "DAU" },
      { value: "10k ARR", label: "Revenue" },
    ],
    links: [
      { label: "Live", href: "https://aloharmony.com" },
      { label: "Web", href: "https://app.aloharmony.com" },
      { label: "Android", href: "https://play.google.com/store/apps/details?id=com.aloharmony.app" },
      { label: "iOS", href: "https://apps.apple.com/us/app/aloharmony/id1597463081" },
    ],
    featured: true,
  },
  {
    title: "Subliful",
    subtitle: "Mobile Companion App",
    description:
      "Mobile companion app built with React Native for iOS and Android. Delivers daily inspiration, reflections, and personal growth challenges. Built as part of the CRIZZ ecosystem with GraphQL backend and subscription management.",
    image: "/projects/subliful.webp",
    placeholderGradient: "from-violet-50 to-purple-100",
    tags: ["React Native", "GraphQL", "Expo", "Node.js"],
    metrics: [],
    links: [
      // { label: "Live", href: "https://subliful.com" },
    ],
    featured: false,
  },
  {
    title: "XProfit",
    subtitle: "Finance Analytics Platform",
    description:
      "Finance analytics platform that extracts accounting data to help businesses understand their financial health and make better decisions. Built the full web platform and backend as Technical Leader at CRIZZ.",
    image: "/projects/xprofit.webp",
    placeholderGradient: "from-emerald-50 to-teal-100",
    tags: ["React", "Node.js", "NestJS", "GraphQL"],
    metrics: [],
    links: [],
    featured: false,
  },
];
---

<section id="work" class="py-24 bg-surface">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Section header -->
    <div class="flex items-end justify-between mb-14">
      <div>
        <p class="font-mono text-xs text-accent uppercase tracking-widest mb-2">Selected Work</p>
        <h2 class="font-display text-4xl font-bold tracking-tight text-ink">Projects</h2>
      </div>
      <a href="https://github.com/dinels12" target="_blank" rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-muted hover:text-ink no-underline transition-colors">
        View all on GitHub
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Featured project -->
    {projects.filter(p => p.featured).map(p => (
      <div class="reveal mb-8 rounded-2xl border border-border bg-canvas overflow-hidden">
        <div class="grid md:grid-cols-2">
          <!-- Image / placeholder -->
          <div class={`relative aspect-4/3 md:aspect-auto bg-linear-to-br ${p.placeholderGradient} overflow-hidden`}>
            {p.image
              ? <img src={p.image} alt={p.title} class="w-full h-full object-contain" loading="lazy" />
              : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="text-center">
                    <div class="w-16 h-16 rounded-2xl bg-white/60 flex items-center justify-center mx-auto mb-3 shadow-sm">
                      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                    <p class="text-xs text-muted/70">Add screenshot to<br/>/public/projects/</p>
                  </div>
                </div>
              )
            }
            <!-- Featured badge -->
            <div class="absolute top-4 left-4 bg-ink/80 backdrop-blur-sm text-canvas text-xs font-semibold px-3 py-1 rounded-full">
              Featured
            </div>
          </div>

          <!-- Content -->
          <div class="p-8 flex flex-col justify-between">
            <div>
              <p class="font-mono text-xs text-accent uppercase tracking-widest mb-2">{p.subtitle}</p>
              <h3 class="font-display text-2xl font-bold text-ink mb-4">{p.title}</h3>
              <p class="text-sm text-ink2 leading-relaxed mb-6">{p.description}</p>

              <!-- Metrics -->
              {p.metrics.length > 0 && (
                <div class="flex gap-6 mb-6 pb-6 border-b border-border">
                  {p.metrics.map(m => (
                    <div>
                      <div class="font-display text-xl font-bold text-ink">{m.value}</div>
                      <div class="text-xs text-muted">{m.label}</div>
                    </div>
                  ))}
                </div>
              )}

              <!-- Tags -->
              <div class="flex flex-wrap gap-1.5">
                {p.tags.map(t => (
                  <span class="text-xs bg-tag-bg text-tag-text border border-blue-100 px-2.5 py-0.5 rounded-full font-medium">{t}</span>
                ))}
              </div>
            </div>

            <!-- Links -->
            {p.links.length > 0 && (
              <div class="flex gap-3 mt-6">
                {p.links.map(l => (
                  <a href={l.href} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent no-underline hover:text-accent2 transition-colors">
                    {l.label}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    ))}

    <!-- Other projects grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.filter(p => !p.featured).map(p => (
        <div class="reveal rounded-xl border border-border bg-canvas overflow-hidden hover:border-border2 hover:shadow-sm transition-all duration-200 flex flex-col">
          <!-- Image / placeholder -->
          <div class={`relative h-44 bg-linear-to-br ${p.placeholderGradient}`}>
            {p.image
              ? <img src={p.image} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
              : (
                <div class="absolute inset-0 flex items-center justify-center opacity-40">
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              )
            }
          </div>

          <!-- Content -->
          <div class="p-5 flex flex-col flex-1">
            <p class="font-mono text-xs text-accent uppercase tracking-widest mb-1">{p.subtitle}</p>
            <h3 class="font-semibold text-base text-ink mb-2">{p.title}</h3>
            <p class="text-sm text-muted leading-relaxed mb-4 flex-1">{p.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {p.tags.map(t => (
                <span class="text-xs bg-surface2 text-ink2 border border-border px-2 py-0.5 rounded font-medium">{t}</span>
              ))}
            </div>
             <!-- Links -->
            {p.links.length > 0 && (
              <div class="flex gap-3 mt-6">
                {p.links.map(l => (
                  <a href={l.href} target="_blank" rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent no-underline hover:text-accent2 transition-colors">
                    {l.label}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                ))}
              </div>
            )}
          </div>
          
        </div>
        
      ))}
    </div>

  </div>
</section>
