---
const education = [
  {
    name: "Introduction to Computer Science (CS50)",
    org: "HarvardX",
    detail: "Online coursework",
    period: "Completed",
  },
];

const languages = [
  { name: "Spanish", level: "Native" },
  { name: "English", level: "Advanced" },
];
---

<section id="education" class="py-24">
  <div class="max-w-3xl mx-auto px-8">

    <div class="flex items-center gap-3 mb-3">
      <span class="font-mono text-xs text-accent uppercase tracking-widest">Background</span>
      <span class="flex-1 h-px bg-border"></span>
    </div>
    <h2 class="font-display font-semibold text-3xl tracking-tighter text-body mb-10">Education</h2>

    <div class="flex flex-col gap-3 mb-14">
      {education.map(edu => (
        <div class="fade-in bg-bg2 border border-border rounded-xl p-5 flex items-start justify-between gap-4">
          <div>
            <div class="text-sm font-semibold text-body">{edu.name}</div>
            <div class="text-xs text-accent3 mt-0.5">{edu.org} — {edu.detail}</div>
          </div>
          <div class="font-mono text-xs text-muted shrink-0">{edu.period}</div>
        </div>
      ))}
    </div>

    <!-- Languages -->
    <div class="flex items-center gap-3 mb-5">
      <span class="font-mono text-xs text-accent uppercase tracking-widest">Languages</span>
      <span class="flex-1 h-px bg-border"></span>
    </div>

    <div class="flex gap-3 flex-wrap">
      {languages.map(lang => (
        <div class="fade-in bg-bg2 border border-border rounded-xl px-7 py-5 text-center">
          <div class="text-sm font-semibold text-body">{lang.name}</div>
          <div class="font-mono text-xs text-muted mt-1">{lang.level}</div>
        </div>
      ))}
    </div>

  </div>
</section>
