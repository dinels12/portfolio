---
const jobs = [
  {
    role: "Sr. Software Engineer / CTO",
    company: "Aloharmony",
    url: "https://aloharmony.com",
    location: "USA · Remote",
    period: "Oct 2024 – Present",
    current: true,
    description: "Lead engineer and technical decision-maker for a meditation platform. Responsible for the full product ecosystem — mobile app, backend APIs, web platform, and cloud infrastructure.",
    highlights: [
      "Scaled platform to 16,000+ registered users and 1,300 daily active users",
      "Built React Native mobile app with offline-first architecture and real-time audio streaming",
      "Designed NestJS + GraphQL backend with 90+ endpoints from scratch",
      "Cut landing load time from ~3s to ~200ms with Next.js SSR and CloudFront CDN",
      "Migrated GraphQL federation microservices to an optimized monolith, reducing operational complexity and latency",
      "Implemented end-to-end Stripe subscription billing including trial flows, dunning management, and webhook handling",
      "Managed full AWS infrastructure: ECS, EC2, S3, CloudFront, Route53, and Redis caching layer",
    ],
    tags: ["React Native", "Next.js", "NestJS", "GraphQL", "AWS", "Stripe", "Docker", "Redis"],
  },
  {
    role: "Technical Leader",
    company: "CRIZZ",
    url: null,
    location: "Colombia · Remote",
    period: "Jun 2022 – Dec 2023",
    current: false,
    description: "Led a 5-engineer team across four simultaneous products, owning architecture decisions, code quality, technical roadmap, and direct collaboration with stakeholders.",
    highlights: [
      "Led cross-functional team of 5 developers across Subliful, Adkiero, Yovoto, and XProfit",
      "Defined technology stacks and architectural patterns for all products",
      "Established coding standards, PR review processes, and sprint cadences",
      "Mentored engineers through code reviews and pair programming sessions, measurably improving team velocity",
      "Collaborated directly with stakeholders to translate business requirements into technical specs and delivery timelines",
    ],
    tags: ["React Native", "Node.js", "GraphQL", "NestJS", "Team Lead"],
  },
  {
    role: "Full Stack Developer",
    company: "Thought Media",
    url: null,
    location: "USA · Remote",
    period: "Jan 2021 – Jan 2022",
    current: false,
    description: "Delivered full-stack features across multiple client projects, from e-commerce platforms to mobile applications.",
    highlights: [
      "Built e-commerce platforms with PayPal and Authorize.net integrations, handling PCI-compliant checkout flows",
      "Shipped TaxMambo React Native app from requirements to App Store deployment",
      "Delivered RESTful backend services and responsive frontend interfaces across multiple client projects",
    ],
    tags: ["React", "React Native", "Node.js", "PayPal", "Authorize.net"],
  },
];
---

<section id="experience" class="py-24 bg-canvas">
  <div class="max-w-5xl mx-auto px-6">

    <div class="mb-14">
      <p class="font-mono text-xs text-accent uppercase tracking-widest mb-2">Career</p>
      <h2 class="font-display text-4xl font-bold tracking-tight text-ink">Experience</h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[7px] top-2 bottom-0 w-px bg-border hidden sm:block"></div>

      <div class="flex flex-col gap-10">
        {jobs.map((job) => (
          <div class="reveal sm:pl-10 relative">
            <!-- Dot -->
            <div class={`absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 bg-canvas hidden sm:block
              ${job.current ? 'border-accent bg-accent' : 'border-border2 bg-surface'}`}></div>

            <div class="bg-surface border border-border rounded-xl p-6 hover:border-border2 hover:shadow-sm transition-all duration-200">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="font-semibold text-base text-ink">{job.role}</h3>
                  <div class="flex items-center gap-2 mt-0.5">
                    {job.url
                      ? <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent no-underline hover:text-accent2">{job.company}</a>
                      : <span class="text-sm font-medium text-accent">{job.company}</span>
                    }
                    <span class="text-xs text-muted">·</span>
                    <span class="text-xs text-muted">{job.location}</span>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  {job.current && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent bg-tag-bg border border-blue-100 px-2.5 py-0.5 rounded-full">
                      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
                      Now
                    </span>
                  )}
                  <span class="font-mono text-xs text-muted">{job.period}</span>
                </div>
              </div>

              <p class="text-sm text-ink2 leading-relaxed mb-4">{job.description}</p>

              <ul class="flex flex-col gap-1.5 mb-5">
                {job.highlights.map(h => (
                  <li class="flex gap-2 text-sm text-muted">
                    <span class="text-accent font-bold shrink-0 mt-0.5">→</span>
                    {h}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {job.tags.map(t => (
                  <span class="text-xs bg-surface2 text-ink2 border border-border px-2.5 py-0.5 rounded font-medium">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
