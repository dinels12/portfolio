---
const jobs = [
  {
    role: "Sr. Software Engineer / CTO",
    company: "Aloharmony",
    url: "https://aloharmony.com",
    location: "USA · Remote",
    period: "Oct 2024 – Present",
    current: true,
    description: "Lead engineer for a meditation platform with 16k+ users. Own everything: backend APIs, mobile app, web platform, and AWS infrastructure.",
    highlights: [
      "Scaled platform to 16,000+ registered users and 1,300 daily active users",
      "Built React Native offline-first mobile app with audio streaming",
      "Designed NestJS + GraphQL backend with 90+ endpoints",
      "Cut landing load time from ~3s to ~200ms with Next.js + CloudFront",
      "Migrated GraphQL federation microservices to an optimized monolith",
      "Managed full AWS stack: ECS, EC2, S3, CloudFront, Route53, Redis",
    ],
    tags: ["React Native", "Next.js", "NestJS", "GraphQL", "AWS", "Stripe", "Docker"],
  },
  {
    role: "Technical Leader",
    company: "CRIZZ",
    url: null,
    location: "Colombia · Remote",
    period: "Jun 2022 – Dec 2023",
    current: false,
    description: "Led a 5-engineer team across four simultaneous products, owning architecture decisions, code quality, and technical roadmap.",
    highlights: [
      "Led cross-functional team of 5 developers across Subliful, Adkiero, Yovoto, and XProfit",
      "Defined technology stacks and architectural patterns for all products",
      "Mentored engineers through code reviews and pair programming sessions",
    ],
    tags: ["React Native", "Node.js", "GraphQL", "Team Lead"],
  },
  {
    role: "Full Stack Developer",
    company: "Thought Media",
    url: null,
    location: "USA · Remote",
    period: "Jan 2021 – Jan 2022",
    current: false,
    description: "Delivered full-stack features for e-commerce clients, including payment integrations and the TaxMambo mobile app.",
    highlights: [
      "Built e-commerce platforms with PayPal and Authorize.net integrations",
      "Shipped TaxMambo React Native app from requirements to App Store",
    ],
    tags: ["React", "React Native", "Node.js", "PayPal", "Authorize.net"],
  },
];
---

<section id="experience" class="py-24 bg-canvas">
  <div class="max-w-5xl mx-auto px-6">

    <div class="mb-14">
      <p class="font-mono text-xs text-accent uppercase tracking-widest mb-2">Career</p>
      <h2 class="font-display text-4xl font-bold tracking-tight text-ink">Experience</h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-[7px] top-2 bottom-0 w-px bg-border hidden sm:block"></div>

      <div class="flex flex-col gap-10">
        {jobs.map((job) => (
          <div class="reveal sm:pl-10 relative">
            <!-- Dot -->
            <div class={`absolute left-0 top-1.5 w-3.5 h-3.5 rounded-full border-2 bg-canvas hidden sm:block
              ${job.current ? 'border-accent bg-accent' : 'border-border2 bg-surface'}`}></div>

            <div class="bg-surface border border-border rounded-xl p-6 hover:border-border2 hover:shadow-sm transition-all duration-200">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="font-semibold text-base text-ink">{job.role}</h3>
                  <div class="flex items-center gap-2 mt-0.5">
                    {job.url
                      ? <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-accent no-underline hover:text-accent2">{job.company}</a>
                      : <span class="text-sm font-medium text-accent">{job.company}</span>
                    }
                    <span class="text-xs text-muted">·</span>
                    <span class="text-xs text-muted">{job.location}</span>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  {job.current && (
                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-accent bg-tag-bg border border-blue-100 px-2.5 py-0.5 rounded-full">
                      <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
                      Now
                    </span>
                  )}
                  <span class="font-mono text-xs text-muted">{job.period}</span>
                </div>
              </div>

              <p class="text-sm text-ink2 leading-relaxed mb-4">{job.description}</p>

              <ul class="flex flex-col gap-1.5 mb-5">
                {job.highlights.map(h => (
                  <li class="flex gap-2 text-sm text-muted">
                    <span class="text-accent font-bold shrink-0 mt-0.5">→</span>
                    {h}
                  </li>
                ))}
              </ul>

              <div class="flex flex-wrap gap-1.5">
                {job.tags.map(t => (
                  <span class="text-xs bg-surface2 text-ink2 border border-border px-2.5 py-0.5 rounded font-medium">{t}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
