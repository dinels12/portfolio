---

<section class="pt-32 pb-24">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-3xl">
      <!-- Status pill -->
      <div
        class="inline-flex items-center gap-2 bg-tag-bg border border-blue-200 text-tag-text text-xs font-semibold px-3 py-1.5 rounded-full mb-8 font-mono tracking-wide"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
        Available for remote roles
      </div>

      <!-- Headline -->
      <h1 class="font-display text-5xl sm:text-6xl font-bold leading-tight tracking-tight text-ink mb-6">
        Hi, I'm Daniel —<br />
        <span class="italic font-normal text-muted">Senior Full-Stack Engineer.</span>
      </h1>

      <!-- Description -->
      <p class="text-lg text-ink2 leading-relaxed mb-10 max-w-xl">
        I'm a software engineer based in <strong class="text-ink font-semibold">Buenos Aires</strong> with 5+ years building
        web and mobile products from the ground up. Currently serving as
        <strong class="text-ink font-semibold">CTO at Aloharmony</strong>, where I architected and shipped a meditation
        platform used by thousands of people daily — solo, across the full stack.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 mb-16">
        <a
          href="/#work"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-ink text-canvas rounded-lg text-sm font-semibold no-underline hover:bg-ink2 transition-colors duration-150"
        >
          See my work
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            ><path d="M5 12h14M12 5l7 7-7 7"></path></svg
          >
        </a>
        <a
          href="mailto:dinels12@gmail.com"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-surface border border-border rounded-lg text-sm font-semibold text-ink no-underline hover:border-border2 transition-colors duration-150"
        >
          Get in touch
        </a>
      </div>

      <!-- Quick stats -->
      <div class="flex flex-wrap gap-8 pt-8 border-t border-border">
        <div>
          <div class="font-display text-3xl font-bold text-ink">5+</div>
          <div class="text-xs text-muted font-medium uppercase tracking-wider mt-0.5">Years experience</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-ink">16k+</div>
          <div class="text-xs text-muted font-medium uppercase tracking-wider mt-0.5">Users on Aloharmony</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-ink">4</div>
          <div class="text-xs text-muted font-medium uppercase tracking-wider mt-0.5">Products shipped end-to-end</div>
        </div>
        <div>
          <div class="font-display text-3xl font-bold text-ink">0→1</div>
          <div class="text-xs text-muted font-medium uppercase tracking-wider mt-0.5">How I like to build</div>
        </div>
      </div>
    </div>
  </div>
</section>
