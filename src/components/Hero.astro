---
---

<section id="hero" class="min-h-screen flex items-center pt-28 pb-20">
  <div class="max-w-3xl mx-auto px-8 w-full">

    <!-- Eyebrow -->
    <div class="flex items-center gap-3 mb-4">
      <span class="block w-6 h-px bg-accent2"></span>
      <span class="font-mono text-xs text-accent2 uppercase tracking-widest">Senior Full-Stack Engineer</span>
    </div>

    <!-- Name -->
    <h1 class="font-display font-bold text-5xl sm:text-6xl leading-none tracking-tighter text-body mb-2">
      Daniel<br />Suarez
    </h1>

    <!-- Tagline -->
    <p class="font-display font-light italic text-xl text-accent mb-6">
      Building products people actually use.
    </p>

    <!-- Description -->
    <p class="text-muted text-sm leading-relaxed max-w-lg mb-8">
      <strong class="text-body font-medium">5+ years</strong> designing and shipping scalable web
      and mobile products. From mobile apps and backend APIs to cloud infrastructure — I work
      across the entire stack. Specialized in
      <strong class="text-body font-medium">React, React Native, Node.js</strong> and
      <strong class="text-body font-medium">AWS</strong>.
    </p>

    <!-- Meta -->
    <div class="flex flex-col gap-2 mb-6">
      <div class="flex items-center gap-2 text-xs text-muted">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Buenos Aires, Argentina
      </div>
      <div class="flex items-center gap-2 text-xs text-muted">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        dinels12@gmail.com
      </div>
    </div>

    <!-- Available badge -->
    <div class="inline-flex items-center gap-2 bg-accent2/10 border border-accent2/25 text-accent2 font-mono text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-accent2 animate-pulse-dot"></span>
      Available for work
    </div>

    <!-- CTA buttons -->
    <div class="flex gap-3 flex-wrap">
      <a
        href="mailto:dinels12@gmail.com"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-bg font-semibold text-sm hover:bg-amber-400 transition-colors duration-200 no-underline"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Get in touch
      </a>
      <a
        href="https://linkedin.com/in/dinels"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-bg3 text-body border border-border font-semibold text-sm hover:border-white/15 hover:bg-bg2 transition-all duration-200 no-underline"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
        LinkedIn
      </a>
    </div>

  </div>
</section>
