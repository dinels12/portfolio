---
const links = [
  { href: "#experience", label: "Experience" },
  { href: "#skills",     label: "Skills" },
  { href: "#education",  label: "Education" },
  { href: "#contact",    label: "Contact" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 h-14 flex items-center justify-between px-8 border-b border-border bg-bg/85 backdrop-blur-md">
  <a href="#hero" class="font-display text-lg font-bold text-accent tracking-tight no-underline">
    ds.
  </a>
  <ul class="hidden md:flex gap-8 list-none m-0 p-0">
    {links.map(l => (
      <li>
        <a
          href={l.href}
          class="text-muted hover:text-body text-xs font-semibold uppercase tracking-widest transition-colors duration-200 no-underline"
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
